---
import "leaflet/dist/leaflet.css";
---

<section id="quienes-somos" class="mx-auto max-w-6xl px-6 py-16 sm:px-8 lg:px-10">
    <div class="rounded-4xl border border-slate-200 bg-slate-900 p-8 text-white shadow-[0_30px_80px_-25px_rgba(15,23,42,0.6)] sm:p-10 lg:p-12">
    <div class="max-w-4xl">
        <h2 class="text-xl font-semibold sm:text-4xl">Contactanos</h2>
        <div class="mt-4 h-1 w-16 rounded-full bg-amber-400"></div>
        <div class="mt-6 flex flex-col gap-8 text-base leading-8 text-slate-200 sm:text-lg lg:flex-row">
            <div class="w-full rounded-md border border-white/10 p-4 transition-all duration-300 hover:border-white/40">
                <h2 class="font-semibold text-2xl ">Direccion</h2>
                <div class="mt-4 h-1 w-16 rounded-full bg-amber-400"></div>
                <p class="mt-5 text-gray-200">Ruta 40 - Km 23 - Rawson</p>
                <div id="mapa" class="mt-4 h-[300px] h-[320px] rounded-lg"></div>
                <button class="rounded-2xl  text-xs">
                    <a href="https://maps.app.goo.gl/AR56nsp4bLHgcYzp6">Ver en Google Maps</a>
                </button>
            </div>
            <div>
                <div class="m-10">
                    <h2 class="text-2xl font-semibold ">Telefono</h2>
                    <div class="mt-4 h-1 w-16 rounded-full bg-amber-400"></div>
                    <p class="mt-5 text-gray-200"> 0264 - 4287599/ 4282315/ 4282376</p>
                </div>
                <div class="m-10">
                    <h2 class="text-xl font-semibold ">Email</h2>
                    <div class="my-4 h-1 w-16 rounded-full bg-amber-400"></div>
                    <a href="mailto:administracion@archivosanjuan.com.ar">
                        administracion@archivosanjuan.com.ar
                    </a>
                </div>
            </div>
        </div>
    </div>
  </div>
</section>

<script>
  import L from "leaflet";
  const initializeMap = () => {
    const mapContainer = document.getElementById("mapa");
    if (!mapContainer || mapContainer.dataset.initialized === "true") return;

    mapContainer.dataset.initialized = "true";

    const map = L.map("mapa").setView([-31.5875, -68.5264], 14);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors",
    }).addTo(map);

    L.marker([-31.586676249422666, -68.52283378744882])
      .addTo(map)
      .bindPopup("Custodia de Archivos San Juan")
      .openPopup();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeMap);
  } else {
    initializeMap();
  }
</script>
